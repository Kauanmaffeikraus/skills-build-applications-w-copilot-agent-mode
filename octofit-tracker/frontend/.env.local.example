# Example .env.local for Codespaces integration
# Copy to .env.local and set VITE_CODESPACE_NAME in Codespaces environment

# When running in GitHub Codespaces, set this to your codespace name (no protocol).
# Example: VITE_CODESPACE_NAME=psychic-space-enigma-p659xqq9qwv276r5
VITE_CODESPACE_NAME=

# If left unset, the frontend will fall back to http://localhost:8000/api